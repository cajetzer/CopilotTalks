{
  "name": "CopilotTraining-slides",
  "version": "1.0.0",
  "description": "Slidev presentation decks for CopilotTraining training modules",
  "scripts": {
    "dev": "slidev --open",
    "dev:polling": "cross-env CHOKIDAR_USEPOLLING=true CHOKIDAR_INTERVAL=1000 slidev --open",
    "build": "slidev build",
    "build-all": "bash scripts/build-all.sh",
    "build-all:verbose": "bash scripts/build-all.sh -v",
    "export": "slidev export",
    "export-pdf": "slidev export --format pdf",
    "export-pptx": "slidev export --format pptx",
    "generate": "node scripts/generate-slides.js",
    "test:404": "node scripts/test-404-redirect.mjs",
    "inspect": "node scripts/inspect-slide.js",
    "inspect:start": "node scripts/inspect-slide.js start",
    "inspect:scan": "node scripts/inspect-slide.js"
  },
  "dependencies": {
    "@slidev/cli": "^52.11.5",
    "@slidev/theme-default": "latest",
    "@slidev/theme-seriph": "^0.25.0",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3"
  }
}
